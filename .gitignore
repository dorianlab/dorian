# =====================================================================
# Dorian .gitignore --- aggressive guard against accidental commits of
# secrets, runtime data, internal docs, agent tooling, and prod deploy
# state. Pair with Conventional Commits + branch protection on the
# default branch.
# =====================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
.installed.cfg
*.manifest
*.spec
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.coverage
.coverage.*
.tox/
.nox/
htmlcov/
.cache

# --- Node / Next.js / Frontend build outputs ---
node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo
.npm
.eslintcache
.stylelintcache
.parcel-cache
.cache
.yarn-integrity
*.tgz
pnpm-debug.log*

# --- Go (gateway) ---
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.pdb
go.work
go.work.sum

# --- Rust (native / engine) ---
target/
Cargo.lock.bak
*.rs.bk

# --- OS / Editor / IDE ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# --- Env / secrets / keys / credentials ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa*
id_ed25519*
*.token
.netrc
secrets.yaml
secrets.yml
secrets.json
config/config.yaml
config/config.local.yaml

# --- Runtime data / caches / state ---
.data/
data/
logs/
*.log
outputs/
backups/
checkpoints/
mlruns/
wandb/
.ipynb_checkpoints/
notebook/
.streamlit/

# --- Database persistence dirs (when running compose locally) ---
mongo/
neo4j/
postgres/
redis/

# --- Internal / agent / Claude tooling (NEVER commit) ---
.claude/
.codex/
.mcp.json
.rsyncignore
memory/
AGENTS.md
CLAUDE.md
PLAN.md
dorian-full-session.md
TODO.md

# --- Internal docs (separate from public docs that the README links) ---
docs/
wiki/
internal/

# --- Private CI / production deployment ---
.gitlab-ci.yml
deploy/
*.production.yaml
*.production.yml
*.prod.yaml
*.prod.yml

# --- Misc artefacts ---
*.pid
*.seed
*.pid.lock
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
coverage/
*.lcov
.nyc_output
